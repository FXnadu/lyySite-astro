---
import Layout from '../layouts/Layout.astro';

const channels = [
	{ label: '邮件', value: 'liuyingying@example.com', href: 'mailto:liuyingying@example.com' },
	{ label: '电话', value: '+86 138-0000-0000', href: null },
	{ label: 'Behance', value: '/liuyingying-portfolio', href: 'https://www.behance.net/' },
	{ label: '微信', value: 'lyy_work（备注来意）', href: null },
];

const availability = [
	{ period: '2026 春', note: '可到岗 3-5 天/周' },
	{ period: '2026 暑期', note: '可全职实习 8-10 周' },
];
---

<Layout
	title="联系 — liuyingying"
	description="想和我聊聊合作、实习或作品？这里是最快找到我的方式。坐标广东。"
>
	<section class="hero">
		<div class="container">
			<h1 class="title">写一封信，<br/>或者只是路过打个招呼</h1>
		</div>
	</section>

	<section class="contact">
		<div class="container grid">
			<div class="channels">
				<h2>找我</h2>
				<ul class="ch-list">
				{
					channels.map((c) => (
						<li>
							<div class="ch-label">{c.label}</div>
							<div class="ch-value">
								{c.href ? (
									<a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
										{c.value}
									</a>
								) : (
									<span>{c.value}</span>
								)}
							</div>
						</li>
					))
				}
				</ul>

				<h2>简历</h2>
				<a class="resume-btn" href="/resume.pdf" download>
					下载 PDF 简历
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4v12m0 0l-5-5m5 5l5-5M4 20h16"/></svg>
				</a>
			</div>

			<aside class="availability">
				<h2>可实习时间</h2>
				<dl class="avail">
					{
						availability.map((a) => (
							<div>
								<dt>{a.period}</dt>
								<dd>{a.note}</dd>
							</div>
						))
					}
				</dl>

				<div class="note-card">
					<h3>我想去的地方</h3>
					<p>
						交互设计、创意编程、动态图形与新媒体艺术方向。
						我更想知道一家团队是怎么"想的"，而不是它"叫什么名字"。
					</p>
				</div>
			</aside>
		</div>
	</section>

	<section class="quote">
		<div class="container">
			<p>最好的回信，常常不在邮箱里，而在下一次见面的开头。</p>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding-block: clamp(56px, 8vw, 96px) clamp(28px, 4vw, 40px);
		border-bottom: 1px solid var(--line);
	}
	.title {
		font-size: clamp(32px, 5vw, 54px);
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1.3;
		margin: 0;
		max-width: 20ch;
		text-wrap: pretty;
	}

	.contact { padding-block: clamp(40px, 6vw, 64px); border-bottom: 1px solid var(--line); }
	.grid {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 56px;
		align-items: start;
	}

	h2 {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0 0 18px;
	}
	.channels h2:not(:first-child) { margin-top: 36px; }

	.ch-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
	.ch-list li {
		display: grid;
		grid-template-columns: 90px 1fr;
		gap: 16px;
		padding: 14px 16px;
		background: var(--bg);
		border: 1.5px solid var(--line);
		border-radius: var(--radius-sm);
		box-shadow: 2px 2px 0 0 var(--line);
	}
	.ch-label {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--accent);
		padding-top: 4px;
	}
	.ch-value { font-size: 16px; }
	.ch-value a {
		color: var(--fg);
		border-bottom: 1px solid transparent;
	}
	.ch-value span { color: var(--fg-muted); }

	.resume-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 13px 20px;
		border-radius: 14px;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		font-size: 15px;
		font-weight: 500;
		border: 1.5px solid var(--accent);
		box-shadow: 3px 3px 0 0 var(--accent);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.resume-btn:hover {
		transform: translate(1px, 1px);
		box-shadow: 2px 2px 0 0 var(--accent);
	}
	.resume-btn:active {
		transform: translate(3px, 3px);
		box-shadow: 0 0 0 0 var(--accent);
	}

	.avail {
		margin: 0;
		display: grid;
		gap: 12px;
	}
	.avail > div {
		padding: 18px 20px;
		background: var(--bg);
		border: 1.5px solid var(--line);
		border-radius: var(--radius-sm);
		border-left: 3px solid var(--accent);
		box-shadow: 3px 3px 0 0 var(--line);
	}
	.avail dt {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--accent);
		margin-bottom: 4px;
	}
	.avail dd {
		margin: 0;
		color: var(--fg);
		font-size: 15px;
	}

	.note-card {
		margin-top: 28px;
		padding: 24px;
		border: 1.5px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg);
		box-shadow: 4px 4px 0 0 var(--line);
	}
	.note-card h3 {
		font-size: 17px;
		margin: 0 0 8px;
	}
	.note-card p {
		margin: 0;
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.65;
	}

	.quote {
		padding-block: clamp(64px, 9vw, 96px);
	}
	.quote p {
		text-align: center;
		font-family: var(--font-display);
		font-size: clamp(20px, 2.6vw, 28px);
		font-weight: 500;
		color: var(--fg);
		max-width: 30ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.grid { grid-template-columns: 1fr; gap: 40px; }
		.ch-list li { grid-template-columns: 80px 1fr; gap: 10px; }
	}
</style>