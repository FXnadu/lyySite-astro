---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const channels = [
	{ label: '邮箱', value: '2228099764@qq.com', href: 'mailto:2228099764@qq.com' },
	{ label: 'QQ', value: '2228099764', href: 'https://wpa.qq.com/msgrd?v=3&uin=2228099764&site=qq&menu=yes' },
	{ label: '微信', value: 'lyy_work', href: 'weixin://contacts/profile/lyy_work' },
	{ label: '手机', value: '暂未公开', href: null },
];

const socials = [
	{ label: 'Bilibili', icon: 'simple-icons:bilibili' },
	{ label: '小红书', icon: 'simple-icons:xiaohongshu' },
	{ label: '微博', icon: 'simple-icons:sinaweibo' },
	{ label: '站酷', icon: 'simple-icons:zcool' },
];


---

<Layout
	title="联系 — liuyingying"
	description="想和我聊聊合作、实习或作品？这里是最快找到我的方式。坐标广东。"
>
	<section class="hero">
		<div class="container">
			<div class="hero-text">
				<h1 class="title">写一封信，<br/>或者只是路过打个招呼</h1>
			</div>
			<img class="hero-image" src="/images/13.png" alt="" aria-hidden="true" />
		</div>
	</section>

	<section class="contact">
		<div class="container grid">
			<div class="channels">
				<ul class="ch-list">
				{
					channels.map((c) => (
						<li>
							<div class="ch-label">{c.label}</div>
							<div class="ch-value">
								{c.href ? (
									<a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
										{c.value}
									</a>
								) : (
									<span>{c.value}</span>
								)}
							</div>
						</li>
					))
				}
				</ul>

				<h2>简历</h2>
				<a class="resume-btn" href="/resume.pdf" download>
					下载 PDF 简历
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4v12m0 0l-5-5m5 5l5-5M4 20h16"/></svg>
				</a>

				<h2>社交账号</h2>
				<div class="social-btns">
				{
					socials.map((s) => (
						<a class="social-btn social-btn--placeholder" href="#" aria-label={s.label} title={s.label}>
							<Icon name={s.icon} size={20} />
						</a>
					))
				}
				</div>
			</div>

		</div>
	</section>

	<section class="quote">
		<div class="container">
			<p>最好的回信，常常不在邮箱里，而在下一次见面的开头。</p>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding-block: clamp(56px, 8vw, 96px) clamp(28px, 4vw, 40px);
		border-bottom: 1px solid var(--line);
		overflow: hidden;
	}
	.hero > .container {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: clamp(24px, 4vw, 48px);
	}
	.hero-text {
		min-width: 0;
	}
	.hero-image {
		width: clamp(180px, 35vw, 520px);
		height: auto;
		mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, #000 30%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, #000 30%, transparent 80%);
	}
	.title {
		font-size: clamp(32px, 5vw, 54px);
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1.3;
		margin: 0;
		max-width: 20ch;
		text-wrap: pretty;
	}

	.contact { padding-block: clamp(40px, 6vw, 64px); border-bottom: 1px solid var(--line); }
	.grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 56px;
		align-items: start;
		max-width: 720px;
	}

	h2 {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--fg-dim);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 40px 0 18px;
	}


	.ch-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0;
		border-top: 1px solid var(--line);
	}
	.ch-list li {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: 24px;
		align-items: baseline;
		padding: 14px 0;
		border-bottom: 1px solid var(--line);
	}
	.ch-label {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
		letter-spacing: 0.06em;
	}
	.ch-value { font-size: 16px; }
	.ch-value a {
		color: var(--fg);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}
	.ch-value a:hover {
		border-bottom-color: var(--accent-yellow);
	}
	.ch-value span { color: var(--fg); }

	.resume-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 13px 20px;
		border-radius: 14px;
		background: color-mix(in srgb, var(--accent-red) 10%, transparent);
		color: var(--accent-red);
		font-size: 15px;
		font-weight: 500;
		border: 1.5px solid var(--accent-red);
		box-shadow: 3px 3px 0 0 var(--accent-red);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.resume-btn:hover {
		transform: translate(1px, 1px);
		box-shadow: 2px 2px 0 0 var(--accent-red);
	}
	.resume-btn:active {
		transform: translate(3px, 3px);
		box-shadow: 0 0 0 0 var(--accent-red);
	}

	.social-btns {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.social-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		color: var(--fg-muted);
		background: transparent;
		border: 1.5px dashed var(--line-strong);
		border-radius: 12px;
		opacity: 0.45;
		transition: opacity 0.2s ease, border-color 0.2s ease;
	}
	.social-btn:hover {
		opacity: 0.7;
		border-color: var(--fg-muted);
	}

	.quote {
		padding-block: clamp(64px, 9vw, 96px);
	}
	.quote p {
		text-align: center;
		font-family: var(--font-display);
		font-size: clamp(20px, 2.6vw, 28px);
		font-weight: 500;
		color: var(--fg);
		max-width: 30ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.grid { grid-template-columns: 1fr; gap: 40px; }
		.ch-list li { grid-template-columns: 80px 1fr; gap: 10px; }
	}
</style>