---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="配色笔记 — liuyingying"
	description="关于配色方案的探索笔记：从暖陶土到三原色，几种不同性格的色彩搭配实验。"
>
	<section class="hero">
		<div class="container">
			<div class="hero-tag">配色笔记</div>
			<h1 class="title">色彩的性格</h1>
			<p class="lede">
				配色方案决定了网站给人的第一印象。同一个人的作品集，换一套配色，
				就会呈现完全不同的气质。这里记录了几组我正在探索的色彩搭配。
			</p>
		</div>
	</section>

	<!-- 方案一：暖陶土（当前） -->
	<section class="palette" id="current">
		<div class="container">
			<div class="scheme-head">
				<span class="scheme-num">01</span>
				<div>
					<h2>暖陶土 · 现在的样子</h2>
					<p class="scheme-desc">
						米白暖灰基底 + 砖红强调色。温暖、含蓄、有质感，像一个安静的下午。
					</p>
				</div>
			</div>

			<div class="swatches">
				<div class="swatch" style="--c: #f6f4ee; --label: '米白暖灰'">
					<div class="swatch-block"><span class="swatch-val">#f6f4ee</span></div>
					<span class="swatch-name">背景 <code>--bg</code></span>
				</div>
				<div class="swatch" style="--c: #ede9e0; --label: '暖灰褐'">
					<div class="swatch-block"><span class="swatch-val">#ede9e0</span></div>
					<span class="swatch-name">柔和面 <code>--bg-soft</code></span>
				</div>
				<div class="swatch" style="--c: #b14e41; --label: '砖红'">
					<div class="swatch-block"><span class="swatch-val">#b14e41</span></div>
					<span class="swatch-name">强调色 <code>--accent</code></span>
				</div>
				<div class="swatch" style="--c: #d87c6f; --label: '浅砖红'">
					<div class="swatch-block"><span class="swatch-val">#d87c6f</span></div>
					<span class="swatch-name">柔和版 <code>--accent-soft</code></span>
				</div>
				<div class="swatch" style="--c: #1b1916; --label: '炭黑'">
					<div class="swatch-block"><span class="swatch-val">#1b1916</span></div>
					<span class="swatch-name">文字色 <code>--fg</code></span>
				</div>
			</div>

			<div class="demo-card" style="--demo-bg: #f6f4ee; --demo-accent: #b14e41; --demo-text: #1b1916;">
				<div class="demo-preview">
					<div class="demo-navbar"><span></span><span></span><span></span></div>
					<div class="demo-body">
						<div class="demo-card-inner">
							<div class="demo-avatar"></div>
							<div>
								<div class="demo-line demo-line--title"></div>
								<div class="demo-line demo-line--sub"></div>
							</div>
						</div>
						<div class="demo-btn-group">
							<span class="demo-btn demo-btn--primary">浏览作品</span>
							<span class="demo-btn demo-btn--ghost">联系我</span>
						</div>
					</div>
				</div>
				<div class="demo-label">
					<strong>气质关键词</strong>
					<span>温暖 · 含蓄 · 大地系 · 人文感</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 方案二：蓝主色 + 黄红点缀 -->
	<section class="palette" id="proposal">
		<div class="container">
			<div class="scheme-head">
				<span class="scheme-num">02</span>
				<div>
					<h2>三原色 · 蓝黄红的对话</h2>
					<p class="scheme-desc">
						以蓝色为主调，黄色和红色作为点缀。活泼、自信、有设计宣言感。
					</p>
				</div>
			</div>

			<div class="swatches">
				<div class="swatch" style="--c: #f5f3f0; --label: '暖白'">
					<div class="swatch-block"><span class="swatch-val">#f5f3f0</span></div>
					<span class="swatch-name">背景 <code>--bg</code></span>
				</div>
				<div class="swatch" style="--c: #4a7c9e; --label: '柔和蓝'">
					<div class="swatch-block"><span class="swatch-val">#4a7c9e</span></div>
					<span class="swatch-name">主色 <code>--primary</code></span>
				</div>
				<div class="swatch" style="--c: #e8b84b; --label: '芥末黄'">
					<div class="swatch-block"><span class="swatch-val">#e8b84b</span></div>
					<span class="swatch-name">点缀色一 <code>--yellow</code></span>
				</div>
				<div class="swatch" style="--c: #c96b5e; --label: '陶土红'">
					<div class="swatch-block"><span class="swatch-val">#c96b5e</span></div>
					<span class="swatch-name">点缀色二 <code>--red</code></span>
				</div>
				<div class="swatch" style="--c: #1a1a1a; --label: '近黑'">
					<div class="swatch-block"><span class="swatch-val">#1a1a1a</span></div>
					<span class="swatch-name">文字色 <code>--fg</code></span>
				</div>
			</div>

			<div class="demo-card" style="--demo-bg: #f5f3f0; --demo-accent: #4a7c9e; --demo-text: #1a1a1a; --demo-secondary: #e8b84b;">
				<div class="demo-preview">
					<div class="demo-navbar" style="background: #4a7c9e;"><span style="background: #e8b84b;"></span><span style="background: #c96b5e;"></span><span style="background: rgba(255,255,255,0.3);"></span></div>
					<div class="demo-body">
						<div class="demo-card-inner">
							<div class="demo-avatar" style="background: #e8b84b;"></div>
							<div>
								<div class="demo-line demo-line--title" style="background: #4a7c9e;"></div>
								<div class="demo-line demo-line--sub" style="background: #c96b5e;"></div>
							</div>
						</div>
						<div class="demo-btn-group">
							<span class="demo-btn demo-btn--primary" style="background: #4a7c9e;">浏览作品</span>
							<span class="demo-btn demo-btn--ghost" style="border-color: #4a7c9e; color: #4a7c9e;">联系我</span>
						</div>
					</div>
				</div>
				<div class="demo-label">
					<strong>气质关键词</strong>
					<span>活泼 · 现代 · 设计感 · 自信</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 对比 -->
	<section class="compare">
		<div class="container">
			<div class="scheme-head">
				<span class="scheme-num">03</span>
				<div>
					<h2>放在一起看</h2>
					<p class="scheme-desc">
						两种配色的性格差异，在相同的页面结构下会更加明显。
					</p>
				</div>
			</div>

			<div class="compare-grid">
				<div class="compare-col" style="--border-c: #b14e41;">
					<div class="compare-head" style="background: #b14e41;">
						<span>暖陶土</span>
					</div>
					<div class="compare-body" style="background: #f6f4ee;">
						<ul class="compare-list">
							<li>像一本旧书的气息</li>
							<li>温和、不争抢注意力</li>
							<li>内容 > 形式</li>
							<li>适合文字和叙事型作品</li>
							<li>感性强于理性</li>
						</ul>
						<div class="compare-tag-group">
							<span class="compare-tag" style="background: #b14e41; color: #fff;">温暖</span>
							<span class="compare-tag" style="background: #d87c6f; color: #fff;">柔软</span>
							<span class="compare-tag" style="background: #ede9e0; color: #1b1916;">大地</span>
						</div>
					</div>
				</div>

				<div class="compare-col" style="--border-c: #4a7c9e;">
					<div class="compare-head" style="background: #4a7c9e;">
						<span>三原色</span>
					</div>
					<div class="compare-body" style="background: #f5f3f0;">
						<ul class="compare-list">
							<li>像一张海报的宣言</li>
							<li>活泼、有视觉冲击力</li>
							<li>形式 = 内容</li>
							<li>适合展示型、视觉型作品</li>
							<li>理性中带着俏皮</li>
						</ul>
						<div class="compare-tag-group">
							<span class="compare-tag" style="background: #4a7c9e; color: #fff;">现代</span>
							<span class="compare-tag" style="background: #e8b84b; color: #1a1a1a;">活泼</span>
							<span class="compare-tag" style="background: #c96b5e; color: #fff;">自信</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 方案三：晴空珊瑚 -->
	<section class="palette" id="sky-coral">
		<div class="container">
			<div class="scheme-head">
				<span class="scheme-num">04</span>
				<div>
					<h2>晴空珊瑚 · 青橙互补</h2>
					<p class="scheme-desc">
						青空蓝与珊瑚橙的互补对话，加上一抹阳光黄。
						像20岁夏天的海边——清新、明亮、有风。
					</p>
				</div>
			</div>

			<div class="swatches">
				<div class="swatch" style="--c: #f7f5f0; --label: '暖白'">
					<div class="swatch-block"><span class="swatch-val">#f7f5f0</span></div>
					<span class="swatch-name">背景 <code>--bg</code></span>
				</div>
				<div class="swatch" style="--c: #2a9dcc; --label: '青空蓝'">
					<div class="swatch-block"><span class="swatch-val">#2a9dcc</span></div>
					<span class="swatch-name">主色 <code>--primary</code></span>
				</div>
				<div class="swatch" style="--c: #e8785a; --label: '珊瑚橙'">
					<div class="swatch-block"><span class="swatch-val">#e8785a</span></div>
					<span class="swatch-name">互补色 <code>--complement</code></span>
				</div>
				<div class="swatch" style="--c: #f2c84b; --label: '阳光黄'">
					<div class="swatch-block"><span class="swatch-val">#f2c84b</span></div>
					<span class="swatch-name">点缀色 <code>--accent</code></span>
				</div>
				<div class="swatch" style="--c: #1a1a2e; --label: '深海蓝'">
					<div class="swatch-block"><span class="swatch-val">#1a1a2e</span></div>
					<span class="swatch-name">文字色 <code>--fg</code></span>
				</div>
			</div>

			<div class="demo-card" style="--demo-bg: #f7f5f0; --demo-accent: #2a9dcc; --demo-text: #1a1a2e;">
				<div class="demo-preview">
					<div class="demo-navbar" style="background: #2a9dcc;"><span style="background: #e8785a;"></span><span style="background: #f2c84b;"></span><span style="background: rgba(255,255,255,0.3);"></span></div>
					<div class="demo-body">
						<div class="demo-card-inner">
							<div class="demo-avatar" style="background: #f2c84b;"></div>
							<div>
								<div class="demo-line demo-line--title" style="background: #2a9dcc;"></div>
								<div class="demo-line demo-line--sub" style="background: #e8785a;"></div>
							</div>
						</div>
						<div class="demo-btn-group">
							<span class="demo-btn demo-btn--primary" style="background: #2a9dcc;">浏览作品</span>
							<span class="demo-btn demo-btn--ghost" style="border-color: #e8785a; color: #e8785a;">联系我</span>
						</div>
					</div>
				</div>
				<div class="demo-label">
					<strong>气质关键词</strong>
					<span>清新 · 阳光 · 有活力 · 像晴朗的下午</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 方案四：粉绿协奏 -->
	<section class="palette" id="pink-mint">
		<div class="container">
			<div class="scheme-head">
				<span class="scheme-num">05</span>
				<div>
					<h2>粉绿协奏 · 粉绿互补</h2>
					<p class="scheme-desc">
						玫瑰粉与薄荷绿的温柔互补，暖黄点缀其中。
						少女感与设计感兼得，像春天的花店橱窗。
					</p>
				</div>
			</div>

			<div class="swatches">
				<div class="swatch" style="--c: #f8f4f0; --label: '暖奶白'">
					<div class="swatch-block"><span class="swatch-val">#f8f4f0</span></div>
					<span class="swatch-name">背景 <code>--bg</code></span>
				</div>
				<div class="swatch" style="--c: #e88d8a; --label: '玫瑰粉'">
					<div class="swatch-block"><span class="swatch-val">#e88d8a</span></div>
					<span class="swatch-name">主色 <code>--primary</code></span>
				</div>
				<div class="swatch" style="--c: #6db5a0; --label: '薄荷绿'">
					<div class="swatch-block"><span class="swatch-val">#6db5a0</span></div>
					<span class="swatch-name">互补色 <code>--complement</code></span>
				</div>
				<div class="swatch" style="--c: #f2c84b; --label: '暖黄'">
					<div class="swatch-block"><span class="swatch-val">#f2c84b</span></div>
					<span class="swatch-name">点缀色 <code>--accent</code></span>
				</div>
				<div class="swatch" style="--c: #2d2d3a; --label: '深炭灰'">
					<div class="swatch-block"><span class="swatch-val">#2d2d3a</span></div>
					<span class="swatch-name">文字色 <code>--fg</code></span>
				</div>
			</div>

			<div class="demo-card" style="--demo-bg: #f8f4f0; --demo-accent: #e88d8a; --demo-text: #2d2d3a;">
				<div class="demo-preview">
					<div class="demo-navbar" style="background: #e88d8a;"><span style="background: #6db5a0;"></span><span style="background: #f2c84b;"></span><span style="background: rgba(255,255,255,0.3);"></span></div>
					<div class="demo-body">
						<div class="demo-card-inner">
							<div class="demo-avatar" style="background: #f2c84b;"></div>
							<div>
								<div class="demo-line demo-line--title" style="background: #e88d8a;"></div>
								<div class="demo-line demo-line--sub" style="background: #6db5a0;"></div>
							</div>
						</div>
						<div class="demo-btn-group">
							<span class="demo-btn demo-btn--primary" style="background: #e88d8a;">浏览作品</span>
							<span class="demo-btn demo-btn--ghost" style="border-color: #6db5a0; color: #6db5a0;">联系我</span>
						</div>
					</div>
				</div>
				<div class="demo-label">
					<strong>气质关键词</strong>
					<span>温柔 · 甜美 · 有层次 · 像春天的花店</span>
				</div>
			</div>
		</div>
	</section>

	<!-- 结语 -->
	<section class="outro">
		<div class="container">
			<p class="outro-text">
				配色没有标准答案，重要的是它能准确传递你想说的话。<br />
				暖陶土是我的底色，但我还想试试——<br />
				如果换一身更明亮的衣服，世界会不会也对我更明亮一些？
			</p>
		</div>
	</section>
</Layout>

<style>
	/* ─── Hero ─── */
	.hero {
		padding-block: clamp(56px, 8vw, 96px) clamp(28px, 4vw, 40px);
		border-bottom: 1px solid var(--line);
	}
	.hero-tag {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--accent);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 16px;
	}
	.title {
		font-size: clamp(36px, 5.5vw, 60px);
		font-weight: 600;
		letter-spacing: 0.02em;
		line-height: 1.2;
		margin: 0 0 16px;
	}
	.lede {
		font-size: 16px;
		color: var(--fg-muted);
		max-width: 54ch;
		line-height: 1.7;
		margin: 0;
	}

	/* ─── Shared ─── */
	.palette,
	.compare {
		padding-block: clamp(48px, 7vw, 80px);
		border-bottom: 1px solid var(--line);
	}

	.scheme-head {
		display: flex;
		align-items: flex-start;
		gap: 18px;
		margin-bottom: 36px;
	}
	.scheme-num {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-dim);
		font-weight: 500;
		flex-shrink: 0;
		margin-top: 4px;
	}
	.scheme-head h2 {
		font-size: clamp(22px, 3.2vw, 30px);
		font-weight: 600;
		margin: 0 0 6px;
	}
	.scheme-desc {
		font-size: 14px;
		color: var(--fg-muted);
		margin: 0;
		line-height: 1.6;
	}

	/* ─── Swatches ─── */
	.swatches {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		margin-bottom: 40px;
	}
	.swatch {
		flex: 1 1 140px;
		min-width: 120px;
	}
	.swatch-block {
		height: 80px;
		border-radius: var(--radius-sm);
		background: var(--c);
		border: 1px solid var(--line);
		display: flex;
		align-items: flex-end;
		padding: 8px 10px;
		transition: transform 0.2s;
	}
	.swatch-block:hover {
		transform: scale(1.03);
	}
	.swatch-val {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--c);
		background: color-mix(in srgb, var(--c) 70%, #000);
		padding: 2px 6px;
		border-radius: 4px;
		opacity: 0;
		transition: opacity 0.2s;
		backdrop-filter: blur(4px);
	}
	.swatch-block:hover .swatch-val {
		opacity: 1;
	}
	.swatch-name {
		display: block;
		margin-top: 6px;
		font-size: 12px;
		color: var(--fg-muted);
	}
	.swatch-name code {
		font-family: var(--font-mono);
		font-size: 11px;
		background: var(--line);
		padding: 1px 5px;
		border-radius: 3px;
	}

	/* ─── Demo Card ─── */
	.demo-card {
		background: var(--demo-bg);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}
	.demo-preview {
		padding: 0;
	}
	.demo-navbar {
		display: flex;
		gap: 6px;
		padding: 12px 16px;
		background: color-mix(in srgb, var(--demo-text) 6%, transparent);
		border-bottom: 1px solid var(--line);
	}
	.demo-navbar span {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--line-strong);
		display: block;
	}
	.demo-body {
		padding: 28px 24px;
		display: flex;
		flex-direction: column;
		gap: 24px;
	}
	.demo-card-inner {
		display: flex;
		align-items: center;
		gap: 14px;
	}
	.demo-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--demo-accent);
		flex-shrink: 0;
	}
	.demo-line {
		height: 10px;
		border-radius: 5px;
		background: color-mix(in srgb, var(--demo-text) 12%, transparent);
	}
	.demo-line--title {
		width: 120px;
		margin-bottom: 6px;
	}
	.demo-line--sub {
		width: 80px;
		height: 8px;
	}
	.demo-btn-group {
		display: flex;
		gap: 10px;
	}
	.demo-btn {
		font-size: 13px;
		padding: 9px 18px;
		border-radius: 8px;
		font-weight: 500;
	}
	.demo-btn--primary {
		background: var(--demo-accent);
		color: #fff;
	}
	.demo-btn--ghost {
		border: 1px solid var(--line-strong);
		color: var(--demo-text);
	}
	.demo-label {
		padding: 14px 24px;
		border-top: 1px solid var(--line);
		background: color-mix(in srgb, var(--demo-bg) 90%, #000);
		font-size: 13px;
		display: flex;
		gap: 18px;
		align-items: center;
	}
	.demo-label strong {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--fg-dim);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	.demo-label span {
		color: var(--fg-muted);
	}

	/* ─── Compare ─── */
	.compare-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px;
	}
