---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', (entry) => entry.data.featured);

const featured = [...projects]
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const skills = [
	{ group: '设计', items: ['品牌识别', '动态图形', '排印与版面', '影像叙事'] },
	{ group: '代码', items: ['JavaScript', 'Three.js / WebGL', 'p5.js', 'TouchDesigner'] },
	{ group: '工艺', items: ['Risograph', '拼贴', '声音采集', 'AR / WebXR'] },
];


---

<Layout>
	<!-- HERO -->
	<section class="hero">
		<div class="container hero-grid">
			<div class="hero-text">
				<p class="eyebrow">
					<span class="blink"></span>
					开放实习机会 · 数字媒体 2026 届 · 广东
				</p>
				<h1 class="title">
					在<span class="hi">媒体</span>与<span class="hi2">叙事</span>
					<br />之间找一道缝隙
				</h1>
				<p class="lede">
					liuyingying（lyy），数字媒体艺术专业在读。我相信"设计"是思考的可视化，"代码"是叙事的延长。
					这里是我用作品练习这件事的地方——交互影像、动态图形、生成式海报与一些失败的实验。
				</p>
				<div class="cta">
					<a class="btn primary" href="/projects">
						浏览作品
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
					</a>
					<a class="btn ghost" href="/about">关于我</a>
				</div>
			</div>


		</div>
	</section>

	<!-- SKILLS -->
	<section class="skills">
		<div class="container">
			<header class="section-head">
				<h2>我能做什么</h2>
				<span class="index">01 · 能力</span>
			</header>
			<div class="skill-grid">
				{
					skills.map((s) => (
						<div class="skill-col">
							<h3>{s.group}</h3>
							<ul>
								{s.items.map((it) => <li>{it}</li>)}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- FEATURED -->
	<section class="featured">
		<div class="container">
			<header class="section-head">
				<h2>精选作品</h2>
				<a class="more" href="/projects">查看全部 →</a>
			</header>
			<div class="grid-featured">
				{featured.map((project) => <ProjectCard project={project} />)}
			</div>
		</div>
	</section>

	<!-- MANIFESTO -->
	<section class="manifesto">
		<div class="container">
			<blockquote>
				<p>
					"做作品不是为了"完成"，而是为了"探出边界"。<br />
					愿意接受不漂亮的过程、未完成的版本与诚实的失败。"
				</p>
			</blockquote>
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding-block: clamp(48px, 8vw, 88px) clamp(40px, 5vw, 64px);
		border-bottom: 1px solid var(--line);
		overflow: hidden;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}
	.hero-text {
		max-width: 760px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.04em;
		color: var(--fg-muted);
		padding: 6px 12px;
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		margin-bottom: 26px;
		background: var(--bg-elev);
	}

	.blink {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 50%, transparent);
		animation: blink 1.8s ease-in-out infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 40%, transparent); }
		50% { opacity: 0.5; box-shadow: 0 0 0 5px transparent; }
	}

	.title {
		font-family: var(--font-display);
		font-size: clamp(40px, 6vw, 76px);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.01em;
		margin: 0 0 24px;
	}

	.hi {
		color: var(--accent);
		font-style: italic;
	}
	.hi2 {
		color: var(--fg-muted);
		font-weight: 400;
		font-style: italic;
	}

	.lede {
		font-size: clamp(16px, 1.6vw, 19px);
		color: var(--fg-muted);
		line-height: 1.75;
		max-width: 50ch;
		margin-bottom: 28px;
	}

	.cta {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 13px 22px;
		border-radius: var(--radius-sm);
		font-size: 15px;
		font-weight: 500;
		transition: transform 0.15s ease, background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}
	.btn svg { transition: transform 0.2s ease; }
	.btn:hover svg { transform: translateX(3px); }

	.btn.primary {
		background: var(--accent);
		color: #fff;
		border: 1px solid var(--accent);
		box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 30%, transparent);
	}
	.btn.primary:hover {
		transform: translateY(-2px);
		background: var(--accent-dim);
		border-color: var(--accent-dim);
		box-shadow: 0 6px 18px color-mix(in srgb, var(--accent) 36%, transparent);
	}

	.btn.ghost {
		color: var(--fg);
		border: 1px solid var(--line-strong);
		background: var(--bg-elev);
	}
	.btn.ghost:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.skills {
		padding-block: clamp(48px, 7vw, 72px);
		border-bottom: 1px solid var(--line);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		margin-bottom: 36px;
		flex-wrap: wrap;
	}
	.section-head h2 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(26px, 4vw, 40px);
		margin: 0;
	}

	.index {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
		letter-spacing: 0.04em;
	}

	.skill-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.skill-col {
		padding: 26px;
		background: var(--bg-elev);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.skill-col:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-md);
	}

	.skill-col h3 {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 500;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 0 0 16px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--line);
	}

	.skill-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.skill-col li {
		font-size: 16px;
		color: var(--fg);
		padding-left: 20px;
		position: relative;
	}
	.skill-col li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent-soft);
	}

	/* Featured */
	.featured {
		padding-block: clamp(48px, 7vw, 72px);
		border-bottom: 1px solid var(--line);
	}

	.more {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-muted);
		transition: color 0.15s ease;
	}
	.more:hover { color: var(--accent); }

	.grid-featured {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}

	/* Manifesto */
	.manifesto {
		padding-block: clamp(64px, 9vw, 96px);
	}

	.manifesto blockquote {
		margin: 0;
		text-align: center;
	}
	.manifesto p {
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(22px, 2.8vw, 32px);
		font-weight: 400;
		line-height: 1.55;
		color: var(--fg);
		max-width: 34ch;
		margin: 0 auto;
	}
	.manifesto p::before {
		content: '“';
		color: var(--accent);
		margin-right: 0.1em;
		font-size: 1.3em;
		line-height: 0;
		vertical-align: middle;
		font-style: normal;
	}
	.manifesto p::after {
		content: '”';
		color: var(--accent);
		margin-left: 0.1em;
		font-size: 1.3em;
		line-height: 0;
		vertical-align: middle;
		font-style: normal;
	}

	@media (max-width: 960px) {
		.hero-grid { grid-template-columns: 1fr; }
		.skill-grid { grid-template-columns: 1fr; gap: 18px; }
		.grid-featured { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 600px) {
		.grid-featured { grid-template-columns: 1fr; gap: 18px; }
	}
</style>