---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', (entry) => entry.data.featured);

const featured = [...projects]
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 3);

const skills = [
	{ group: '设计', items: ['品牌识别', '动态图形', '排印与版面', '影像叙事'] },
	{ group: '代码', items: ['JavaScript', 'Three.js / WebGL', 'p5.js', 'TouchDesigner'] },
	{ group: '工艺', items: ['Risograph', '拼贴', '声音采集', 'AR / WebXR'] },
];

const timeline = [
	{ year: '2018', title: '初识设计', desc: '高中担任校刊美编，第一次意识到"布局"是一种说话方式。' },
	{ year: '2021', title: '考入数字媒体艺术专业', desc: '开始系统学习视听语言、动态图形与交互设计基础。' },
	{ year: '2023', title: '校园独立放映展策展', desc: '与同学策划三场主题短片联映，主导整体视觉与现场动线。' },
	{ year: '2024', title: '商业插画 / 品牌合作', desc: '为两家本地独立咖啡馆设计季节性视觉物料。' },
	{ year: '2025', title: 'AR 装置驻地创作', desc: '在地市级博物馆完成《回声》驻地项目并长期展出。' },
];


---

<Layout autohideHeader={true}>
	<!-- HERO -->
	<section class="hero">
		<div class="container hero-grid">
			<div class="hero-text">
				<h1 class="title">
					liuyingying（lyy）<br />
					<span class="subtitle">数字媒体艺术</span>
				</h1>
				<p class="lede">
					liuyingying（lyy），数字媒体艺术在读，2026 届，base 广东，正在找实习。这个站收录了过去两年跟叙事有关的尝试——交互影像、动态设计、生成式视觉、还有自己印的 zine。有的做完了，有的还在改，也有一些不太满意的。
				</p>

			</div>


		</div>
	</section>

	<!-- SKILLS -->
	<section class="skills">
		<div class="container">
			<header class="section-head">
				<h2><Icon name="lucide:wand-2" size={24} /> 我能做什么</h2>
				<span class="index">01 · 能力</span>
			</header>
			<div class="skill-grid">
				{
					skills.map((s) => (
						<div class="skill-col">
							<h3>{s.group}</h3>
							<ul>
								{s.items.map((it) => <li>{it}</li>)}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ABOUT -->
	<section class="about" id="about">
		<div class="container">
			<header class="section-head">
				<h2><Icon name="lucide:notebook-pen" size={24} /> 简述</h2>
			</header>
			<div class="grid">
			<div class="bio">
				<p>
					就读于某省属艺术院校数字媒体艺术专业，目前大三。过去三年里，我从"会拼版的人"逐渐变成愿意"写一点代码"的人，
					因为我相信，在数媒领域里，good 和 great 之间的差距，常常取决于你愿不愿意多走半步到工程里去看一眼。
				</p>
				<p>
					我不擅长一次性完成。更愿意把作品做成持续修订的过程：第一版不漂亮没关系，但每修订一次，边界就该清晰一寸。
				</p>
			</div>
			<aside class="info">
				<div class="avatar">
					<img src="/images/logo.png" alt="liuyingying 头像" width="96" height="96" />
				</div>
				<h2>信息</h2>
				<dl>
					<dt>专业</dt><dd>数字媒体艺术</dd>
					<dt>方向</dt><dd>视频剪辑，建模</dd>
					<dt>毕业</dt><dd>2027 届</dd>
					<dt>城市</dt><dd>广东 / 求职中</dd>
				</dl>
			</aside>
		</div>
		</div>
	</section>

	<!-- TIMELINE -->
	<section class="timeline-section">
		<div class="container">
			<header class="section-head">
				<h2><Icon name="lucide:bike" size={24} /> 路径</h2>
				<span class="index">A · 时间线</span>
			</header>
			<ol class="timeline">
				{
					[...timeline].reverse().map((item) => (
						<li>
							<span class="y">{item.year}</span>
							<div class="t">
								<h3>{item.title}</h3>
								<p>{item.desc}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<!-- FEATURED -->
	<section class="featured">
		<div class="container">
			<header class="section-head">
				<h2><Icon name="lucide:sparkle" size={24} /> 精选作品</h2>
				<a class="more" href="/projects">查看全部 →</a>
			</header>
			<ul class="featured-list">
				{
					featured.map((project) => (
						<li>
							<a href={`/projects/${project.id}`}>
								<span class="title">{project.data.title}</span>
								<time class="date" datetime={project.data.pubDate.toISOString()}>
									{project.data.pubDate.toLocaleDateString('zh-CN', {
										year: 'numeric',
										month: '2-digit',
									})}
								</time>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<!-- MANIFESTO -->
	<section class="manifesto">
		<div class="container">
			<blockquote>
				<p>
					愿意接受不漂亮的过程、未完成的版本与诚实的失败。
				</p>
			</blockquote>
		</div>
	</section>
</Layout>

<script is:inline>
	(function () {
		// 首页顶栏自动隐藏：滚动经过 banner 后再出现
		const header = document.querySelector('.site-header');
		const hero = document.querySelector('.hero');
		if (!header || !hero) return;

		header.dataset.visible = 'false';

		const observer = new IntersectionObserver(
			([entry]) => {
				header.dataset.visible = String(!entry.isIntersecting);
			},
			{ threshold: 0 }
		);
		observer.observe(hero);
	})();
</script>

<style>
	.hero {
		min-height: 100vh;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-block: calc(72px + clamp(48px, 8vw, 88px)) clamp(40px, 5vw, 64px);
		overflow: hidden;
		position: relative;
		background: linear-gradient(135deg, var(--accent-blue) 0%, #38b6ff 100%);
		color: #fff;
	}
	.hero::before {
		content: '';
		position: absolute;
		z-index: 0;
		top: -20%;
		right: -6%;
		width: 420px;
		height: 420px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(255,255,255,0.16) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		width: 100%;
	}
	.hero-text {
		max-width: 760px;
		position: relative;
		z-index: 1;
	}

	.title {
		font-family: var(--font-display);
		font-size: clamp(40px, 6vw, 76px);
		font-weight: 600;
		line-height: 1.15;
		letter-spacing: -0.01em;
		margin: 0 0 24px;
	}

	.subtitle {
		font-size: 0.45em;
		font-weight: 400;
		color: rgba(255,255,255,0.72);
	}

	.lede {
		font-size: clamp(16px, 1.6vw, 19px);
		color: rgba(255,255,255,0.82);
		line-height: 1.75;
		max-width: 50ch;
		margin-bottom: 28px;
	}

	.cta {
		display: flex;
		gap: 28px;
		align-items: center;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-display);
		font-size: 17px;
		font-weight: 500;
		color: #fff;
		padding-bottom: 3px;
		border-bottom: 2px solid rgba(255,255,255,0.42);
		transition: gap 0.25s, border-color 0.25s;
	}
	.btn:hover {
		gap: 14px;
		border-color: rgba(255,255,255,0.9);
	}

	.skills {
		padding-block: clamp(48px, 7vw, 72px);
		border-bottom: 1px solid var(--line);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		margin-bottom: 36px;
		flex-wrap: wrap;
	}
	.section-head h2 {
		display: inline-flex;
		align-items: baseline;
		gap: 10px;
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(26px, 4vw, 40px);
		margin: 0;
	}
	.section-head h2 :global(svg) {
		transform: translateY(2px);
	}

	.index {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
		letter-spacing: 0.04em;
	}

	.skill-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}

	.skill-col {
		padding: 22px;
		border: 1.5px solid var(--line-strong);
		border-radius: 14px;
		position: relative;
	}

	.skill-col:nth-child(1) {
		border-color: var(--accent-blue);
		box-shadow: 3px 3px 0 0 var(--accent-blue);
	}
	.skill-col:nth-child(2) {
		border-color: var(--accent-yellow);
		box-shadow: 3px 3px 0 0 var(--accent-yellow);
	}
	.skill-col:nth-child(3) {
		border-color: var(--accent-red);
		box-shadow: 3px 3px 0 0 var(--accent-red);
	}

	.skill-col h3 {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		color: var(--fg);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0 0 14px;
		padding-left: 14px;
		position: relative;
	}
	.skill-col h3::before {
		content: '';
		position: absolute;
		left: 0;
		top: 2px;
		bottom: 2px;
		width: 4px;
		border-radius: 2px;
	}
	.skill-col:nth-child(1) h3::before { background: var(--accent-blue); }
	.skill-col:nth-child(2) h3::before { background: var(--accent-yellow); }
	.skill-col:nth-child(3) h3::before { background: var(--accent-red); }

	.skill-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.skill-col li {
		font-size: 15px;
		color: var(--fg);
		line-height: 1.65;
	}

	/* About */
	.about {
		padding-block: clamp(48px, 7vw, 72px);
		border-bottom: 1px solid var(--line);
	}
	.grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 48px;
		align-items: start;
	}
	.bio h2, .info h2 {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 600;
		color: var(--fg);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		margin-bottom: 20px;
	}
	.bio p {
		font-size: 16px;
		color: var(--fg-muted);
		line-height: 1.75;
		margin-bottom: 14px;
	}
	.info {
		padding: 28px 28px 26px;
		background: transparent;
		border: 1px solid var(--line-strong);
		border-radius: 16px;
		box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
		position: relative;
	}
	.avatar {
		display: flex;
		justify-content: center;
		margin-bottom: 20px;
	}
	.avatar img {
		width: 96px;
		height: 96px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid var(--line-strong);
		padding: 3px;
		background: var(--surface);
	}
	.info dl {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 10px 16px;
		margin: 0;
	}
	.info dt {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		color: var(--accent);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding-top: 4px;
	}
	.info dd {
		margin: 0;
		color: var(--fg);
		font-size: 14px;
	}

	/* Timeline */
	.timeline-section {
		padding-block: clamp(40px, 6vw, 64px);
		border-bottom: 1px solid var(--line);
	}
	.timeline {
		list-style: none;
		padding: 0;
		margin: 0;
		position: relative;
	}
	.timeline::before {
		content: '';
		position: absolute;
		left: 84px;
		top: 28px;
		bottom: 28px;
		width: 1px;
		background: var(--line-strong);
	}
	.timeline li {
		display: grid;
		grid-template-columns: 72px 1fr;
		gap: 24px;
		padding-block: 16px 20px;
		position: relative;
	}
	.timeline li::after {
		content: '';
		position: absolute;
		left: 78px;
		top: 21px;
		width: 13px;
		height: 13px;
		border-radius: 3px;
		background: var(--accent-blue);
		box-shadow: 2px 2px 0 0 color-mix(in srgb, var(--accent-blue) 50%, transparent);
	}
	.timeline .y {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--accent-blue);
		text-align: right;
		padding-top: 2px;
	}
	.timeline .t h3 {
		font-size: 18px;
		margin: 0 0 6px;
	}
	.timeline .t p {
		margin: 0;
		color: var(--fg-muted);
		font-size: 15px;
		line-height: 1.6;
	}

	/* Featured */
	.featured {
		padding-block: clamp(48px, 7vw, 72px);
		border-bottom: 1px solid var(--line);
	}

	.more {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--accent);
		padding: 8px 16px;
		border: 1.5px solid var(--accent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		box-shadow: 3px 3px 0 0 var(--accent);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.more:hover {
		transform: translate(1px, 1px);
		box-shadow: 2px 2px 0 0 var(--accent);
	}
	.more:active {
		transform: translate(3px, 3px);
		box-shadow: 0 0 0 0 var(--accent);
	}

	.featured-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.featured-list li {
		border-bottom: 1px solid var(--line);
	}
	.featured-list li:last-child {
		border-bottom: none;
	}
	.featured-list a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 16px;
		padding: 16px 0;
		font-size: 17px;
		color: var(--fg);
		text-decoration: none;
		transition: color 0.2s;
	}
	.featured-list a:hover {
		color: var(--accent);
	}
	.featured-list .title {
		font-weight: 500;
	}
	.featured-list .date {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-dim);
		flex-shrink: 0;
	}

	/* Manifesto */
	.manifesto {
		padding-block: clamp(64px, 9vw, 96px);
	}

	.manifesto blockquote {
		margin: 0;
		text-align: center;
		padding: clamp(32px, 5vw, 56px) clamp(24px, 4vw, 48px);
		border-radius: 24px;
		position: relative;
	}
	
	.manifesto p {
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(22px, 2.8vw, 32px);
		font-weight: 400;
		line-height: 1.55;
		color: var(--fg);
		max-width: 34ch;
		margin: 0 auto;
	}
	.manifesto p::before {
		content: '“';
		color: var(--accent-red);
		margin-right: 0.1em;
		font-size: 1.3em;
		line-height: 0;
		vertical-align: middle;
		font-style: normal;
	}
	.manifesto p::after {
		content: '”';
		color: var(--accent-red);
		margin-left: 0.1em;
		font-size: 1.3em;
		line-height: 0;
		vertical-align: middle;
		font-style: normal;
	}

	@media (max-width: 960px) {
		.hero-grid { grid-template-columns: 1fr; }
		.skill-grid { grid-template-columns: 1fr; }
		.grid { grid-template-columns: 1fr; gap: 24px; }
	}
</style>