---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const sorted = [...projects].sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const pageLinks = [
	{ href: '/huihua', label: '绘画', desc: '一些水彩与数码绘画的习作。' },
	{ href: '/lianxi', label: '练习', desc: '存放练习图片与随手记录的地方。' },
	{ href: '/suitanglianxi', label: 'UI设计练习', desc: 'UI 设计相关的课堂练习与实践记录。' },
	{ href: '/sheying', label: '摄影', desc: '用镜头捕捉光影与日常的片刻。' },
];
---

<Layout
	title="作品 — liuyingying"
	description="liuyingying 的作品索引：交互叙事、动态图形、生成式海报与 AR 装置实验。"
>
	<section class="head">
		<div class="container">
			<div class="head-text">
				<h1 class="title">做过的尝试 · 正在做的事</h1>
				<p class="lede">
					有些是课上交的作业，有些是帮朋友做的活儿，还有一些是自己瞎折腾到半夜的东西。
					说不上每个都"完成"了，但每一个都让我多学会了点什么。
				</p>
			</div>
			<img class="head-image" src="/images/17.jpg" alt="" aria-hidden="true" />
		</div>
	</section>

	<section class="list container">
		<div class="grid" data-grid>
			{sorted.map((project) => <ProjectCard project={project} />)}
		</div>

		<ul class="page-links">
			{
				pageLinks.map((p) => (
					<li>
						<a href={p.href}>
							<span class="label">{p.label}</span>
							<span class="desc">{p.desc}</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.head {
		padding-block: clamp(48px, 7vw, 80px) clamp(28px, 4vw, 40px);
		overflow: hidden;
	}
	.head > .container {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: clamp(24px, 4vw, 48px);
	}
	.head-text {
		min-width: 0;
	}
	.head-image {
		width: clamp(180px, 35vw, 520px);
		height: auto;
		mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 30%, transparent 80%);
		-webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 30%, transparent 80%);
	}
	.title {
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.01em;
		margin-bottom: 16px;
	}
	.lede {
		color: var(--fg-muted);
		font-size: clamp(16px, 1.6vw, 18px);
		max-width: 60ch;
		line-height: 1.7;
		margin-bottom: 28px;
	}

	.list {
		padding-block: clamp(24px, 3vw, 36px) clamp(40px, 6vw, 64px);
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
	}

	@media (max-width: 1100px) { .grid { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 860px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }

	.page-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.page-links li {
		border-radius: 14px;
		position: relative;
		background: transparent;
		border: 1.5px solid var(--line-strong);
		box-shadow: 3px 3px 0 0 var(--line);
		transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
	}
	.page-links li:hover {
		transform: translate(1px, 1px);
		box-shadow: 2px 2px 0 0 var(--line);
	}
	.page-links li:active {
		transform: translate(3px, 3px);
		box-shadow: 0 0 0 0 var(--line);
	}
	.page-links a {
		display: grid;
		gap: 8px 24px;
		padding: 20px 24px;
		width: 100%;
		color: var(--fg);
		text-decoration: none;
		border-radius: 14px;
	}
	.page-links .label {
		grid-column: 1;
		font-size: clamp(18px, 2.2vw, 24px);
		font-weight: 600;
	}
	.page-links .desc {
		grid-column: 1;
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.55;
	}

</style>
