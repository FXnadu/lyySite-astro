---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');

const sorted = [...projects].sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const pageLinks = [
	{ href: '/huihua', label: '绘画', desc: '一些水彩与数码绘画的习作。' },
	{ href: '/notes', label: '笔记', desc: '关于配色、设计与代码的思考。' },
	{ href: '/sheying', label: '摄影', desc: '用镜头捕捉光影与日常的片刻。' },
];
---

<Layout
	title="作品 — liuyingying"
	description="liuyingying 的作品索引：交互叙事、动态图形、生成式海报与 AR 装置实验。"
>
	<section class="head">
		<div class="container">
			<h1 class="title">做过的尝试 · 正在做的事</h1>
			<p class="lede">
				有些是课上交的作业，有些是帮朋友做的活儿，还有一些是自己瞎折腾到半夜的东西。
				说不上每个都"完成"了，但每一个都让我多学会了点什么。
			</p>
		</div>
	</section>

	<section class="list container">
		<div class="grid" data-grid>
			{sorted.map((project) => <ProjectCard project={project} />)}
		</div>

		<ul class="page-links">
			{
				pageLinks.map((p) => (
					<li>
						<a href={p.href}>
							<span class="label">{p.label}</span>
							<span class="desc">{p.desc}</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>

<style>
	.head {
		padding-block: clamp(48px, 7vw, 80px) clamp(28px, 4vw, 40px);
		border-bottom: 1px solid var(--line);
	}
	.title {
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.01em;
		margin-bottom: 16px;
	}
	.lede {
		color: var(--fg-muted);
		font-size: clamp(16px, 1.6vw, 18px);
		max-width: 60ch;
		line-height: 1.7;
		margin-bottom: 28px;
	}

	.list {
		padding-block: clamp(40px, 6vw, 64px);
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
	}

	@media (max-width: 1100px) { .grid { grid-template-columns: repeat(3, 1fr); } }
	@media (max-width: 860px) { .grid { grid-template-columns: repeat(2, 1fr); } }
	@media (max-width: 540px) { .grid { grid-template-columns: 1fr; } }

	.page-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.page-links li {
		border: 1.5px solid var(--line);
		border-radius: var(--radius-sm);
		background: var(--bg);
		box-shadow: 3px 3px 0 0 var(--line);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.page-links li:hover {
		transform: translate(2px, 2px);
		box-shadow: 1px 1px 0 0 var(--line);
	}
	.page-links a {
		display: grid;
		gap: 8px 24px;
		padding: 20px 24px;
		width: 100%;
		color: var(--fg);
		transition: color 0.2s;
	}
	.page-links a:hover {
		color: var(--accent);
	}
	.page-links .label {
		grid-column: 1;
		font-size: clamp(18px, 2.2vw, 24px);
		font-weight: 600;
	}
	.page-links .desc {
		grid-column: 1;
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.55;
	}

</style>
