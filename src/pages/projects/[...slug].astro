---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, description, pubDate, tags, link } = project.data;
const { Content } = await render(project);

const isPalette = project.id === 'color-palette';

const all = await getCollection('projects');
const others = all
	.filter((p) => p.id !== project.id)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 2);

const palette: Record<string, [string, string]> = {
	'motion-brand': ['#e85d3e', '#f5a623'],
	'tidal-doc': ['#26b6a8', '#1e62c9'],
	'sound-terrain': ['#9b5cf6', '#f25c54'],
	'neon-posters': ['#ff2e7e', '#6b2dff'],
	'ar-echo': ['#2fd889', '#22b6a8'],
};
const [c1, c2] = palette[project.data.cover ?? 'motion-brand'] ?? palette['motion-brand'];

const formatted = pubDate.toLocaleDateString('zh-CN', {
	year: 'numeric', month: 'long', day: 'numeric',
});
---

<Layout
	title={`${title} — liuyingying`}
	description={description}
	image="/og.svg"
>
	<article>
		{isPalette ? (
			<Content />
		) : (
		<header class="p-head">
			<div class="container">
				<a class="back" href="/projects">← 返回作品</a>
				<h1 class="ttl">{title}</h1>
				<p class="desc">{description}</p>
				<div class="meta-row">
					<time datetime={pubDate.toISOString()}>{formatted}</time>
					{
						link && (
							<a class="ext" href={link} target="_blank" rel="noopener">
								访问外部链接 ↗
							</a>
						)
					}
				</div>
				{
					tags.length > 0 && (
						<ul class="tags">
							{tags.map((tag) => <li>{tag}</li>)}
						</ul>
					)
				}
			</div>
		</header>

		<div class="banner" style={`--c1:${c1};--c2:${c2};`} aria-hidden="true">
			<div class="container">
				<div class="banner-shape">
					<svg viewBox="0 0 1000 380" preserveAspectRatio="xMidYMid slice">
						<defs>
							<linearGradient id="bgrad" x1="0" y1="0" x2="1" y2="1">
								<stop offset="0%" stop-color={c1}/>
								<stop offset="100%" stop-color={c2}/>
							</linearGradient>
							<filter id="bnoise">
								<feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="2"/>
								<feColorMatrix type="saturate" values="0"/>
							</filter>
						</defs>
						<rect width="1000" height="380" fill="url(#bgrad)"/>
						<g opacity="0.10" filter="url(#bnoise)"><rect width="1000" height="380"/></g>
						<g stroke="rgba(0,0,0,0.30)" fill="none" stroke-width="2" stroke-linecap="round">
							<circle cx="760" cy="100" r="220"/>
							<circle cx="200" cy="280" r="160"/>
							<line x1="0" y1="280" x2="1000" y2="120"/>
						</g>
					</svg>
				</div>
			</div>
		</div>

		<div class="container prose-wrap">
			<div class="prose">
				<Content />
			</div>
		</div>
		)}

		{
			others.length > 0 && (
				<section class="related">
					<div class="container">
						<h2>其他作品</h2>
						<ul class="rel-list">
							{others.map((p) => (
								<li>
									<a href={`/projects/${p.id}`}>
										<span class="r-date">
											{p.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit' })}
										</span>
										<span class="r-title">{p.data.title}</span>
										<span class="arrow">→</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				</section>
			)
		}
	</article>
</Layout>

<style>
	.p-head {
		padding-block: clamp(40px, 6vw, 64px) clamp(28px, 4vw, 36px);
	}
	.back {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--accent);
		padding: 8px 14px;
		border: 1.5px solid var(--accent);
		border-radius: 10px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		box-shadow: 2px 2px 0 0 var(--accent);
		margin-bottom: 22px;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.back:hover {
		transform: translate(1px, 1px);
		box-shadow: 1px 1px 0 0 var(--accent);
	}

	.ttl {
		font-size: clamp(34px, 6vw, 64px);
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.1;
		margin: 0 0 16px;
		max-width: 18ch;
	}
	.desc {
		font-size: clamp(17px, 2vw, 22px);
		color: var(--fg-muted);
		line-height: 1.55;
		max-width: 50ch;
		margin: 0 0 24px;
	}

	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-dim);
	}
	.ext {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		color: var(--accent);
		padding: 5px 11px;
		border: 1.5px solid var(--accent);
		border-radius: 8px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		box-shadow: 2px 2px 0 0 var(--accent);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.ext:hover {
		transform: translate(1px, 1px);
		box-shadow: 1px 1px 0 0 var(--accent);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		list-style: none;
		padding: 0;
		margin: 22px 0 0;
	}
	.tags li {
		font-size: 12px;
		font-family: var(--font-mono);
		color: var(--accent);
		padding: 4px 10px;
		border: 1.5px solid var(--accent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}

	.banner { padding-top: 16px; }
	.banner-shape {
		border-radius: var(--radius);
		overflow: hidden;
		border: 1.5px solid var(--line);
		box-shadow: 4px 4px 0 0 var(--line);
	}
	.banner-shape svg { display: block; width: 100%; height: auto; }

	.prose-wrap { padding-block: clamp(36px, 5vw, 56px); }
	.prose {
		max-width: 68ch;
		margin-inline: auto;
	}
	.prose :global(h2) {
		font-size: clamp(22px, 3vw, 30px);
		margin: 2.2em 0 0.6em;
		color: var(--fg);
	}
	.prose :global(h2)::before {
		content: '— ';
		color: var(--accent);
	}
	.prose :global(p) {
		font-size: 17px;
		line-height: 1.8;
		color: var(--fg);
		margin-bottom: 1.1em;
	}
	.prose :global(ul) {
		padding-left: 1.2em;
		margin: 0 0 1.2em;
	}
	.prose :global(li) {
		margin-bottom: 0.4em;
		line-height: 1.7;
		color: var(--fg-muted);
	}

	.related {
		padding-block: clamp(36px, 5vw, 48px);
		border-top: 1px solid var(--line);
	}
	.related h2 {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 18px;
	}
	.rel-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.rel-list {
		display: grid;
		gap: 12px;
	}
	.rel-list a {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 16px;
		background: var(--bg);
		border: 1.5px solid var(--line);
		border-radius: var(--radius-sm);
		box-shadow: 3px 3px 0 0 var(--line);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.rel-list a:hover {
		transform: translate(-1px, -1px);
		box-shadow: 4px 4px 0 0 var(--line);
	}
	.r-date {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--fg-dim);
		min-width: 64px;
	}
	.r-title {
		flex: 1;
		font-size: 18px;
		color: var(--fg);
	}
	.arrow { color: var(--fg-dim); }
</style>