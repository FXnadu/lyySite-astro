---
import { Icon } from 'astro-icon/components';

export interface Props {
	autohide?: boolean;
}
const { autohide = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? path === '/' : path.startsWith(href);

const nav = [
	{ href: '/', label: '首页', icon: 'lucide:compass' },
	{ href: '/projects', label: '作品', icon: 'lucide:palette' },
	{ href: '/contact', label: '联系', icon: 'lucide:feather' },
];
---

<header class="site-header" data-autohide={autohide ? 'true' : undefined}>
	<div class="container bar">
		<a class="brand" href="/" aria-label="返回首页">
			<img class="mark" src="/images/logo.png" alt="" aria-hidden="true" />
			<span class="brand-text">liuyingying</span>
		</a>

		<button
			class="menu-toggle"
			type="button"
			aria-label="切换导航"
			aria-expanded="false"
			aria-controls="primary-nav"
		>
			<span class="menu-bar"></span>
			<span class="menu-bar"></span>
		</button>

		<nav id="primary-nav" class="primary-nav" aria-label="主导航">
			{
				nav.map((item) => {
					const color =
						item.href === '/' ? 'blue' :
						item.href === '/projects' ? 'yellow' : 'red';
					return (
						<a
							class:list={['nav-link', { active: isActive(item.href) }]}
							href={item.href}
							aria-current={isActive(item.href) ? 'page' : undefined}
							data-color={color}
						>
							<Icon name={item.icon} size={16} />
							{item.label}
						</a>
					);
				})
			}
		</nav>
	</div>
</header>

<style>
	/* ── 默认粘性顶栏（所有页面） ── */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--bg) 72%, transparent);
		backdrop-filter: blur(28px) saturate(160%);
		border-bottom: 1px solid var(--line-strong);
	}

	/* ── 首页自动隐藏模式 ── */
	.site-header[data-autohide="true"] {
		position: fixed;
		left: 0;
		right: 0;
		transform: translateY(-100%);
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}
	.site-header[data-autohide="true"][data-visible="true"] {
		transform: translateY(0);
		pointer-events: auto;
	}

	.bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 72px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.06em;
		color: var(--fg);
		text-transform: uppercase;
	}
	.brand:focus-visible {
		outline: none;
	}

	.mark {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		object-fit: cover;
		display: block;
	}

	.primary-nav {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.nav-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 14px;
		font-weight: 500;
		color: var(--fg-muted);
		padding: 8px 2px;
		margin: 0 12px;
		position: relative;
		transition: color 0.2s;
	}
	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 100%;
		height: 2px;
		background: var(--accent-blue);
		transform: scaleX(0);
		transition: transform 0.2s, background 0.2s;
	}
	.nav-link:focus-visible {
		outline: none;
	}
	/* ── 每个链接各自的颜色（悬浮、聚焦、选中） ── */
	.nav-link[data-color="blue"]:hover,
	.nav-link[data-color="blue"]:focus-visible,
	.nav-link[data-color="blue"].active {
		color: var(--accent-blue);
	}
	.nav-link[data-color="blue"]:hover::after,
	.nav-link[data-color="blue"]:focus-visible::after,
	.nav-link[data-color="blue"].active::after {
		background: var(--accent-blue);
		transform: scaleX(1);
	}
	.nav-link[data-color="yellow"]:hover,
	.nav-link[data-color="yellow"]:focus-visible,
	.nav-link[data-color="yellow"].active {
		color: var(--accent-yellow);
	}
	.nav-link[data-color="yellow"]:hover::after,
	.nav-link[data-color="yellow"]:focus-visible::after,
	.nav-link[data-color="yellow"].active::after {
		background: var(--accent-yellow);
		transform: scaleX(1);
	}
	.nav-link[data-color="red"]:hover,
	.nav-link[data-color="red"]:focus-visible,
	.nav-link[data-color="red"].active {
		color: var(--accent-red);
	}
	.nav-link[data-color="red"]:hover::after,
	.nav-link[data-color="red"]:focus-visible::after,
	.nav-link[data-color="red"].active::after {
		background: var(--accent-red);
		transform: scaleX(1);
	}


	.menu-toggle {
		display: none;
		width: 40px;
		height: 40px;
		border: 1px solid var(--line);
		background: transparent;
		border-radius: 10px;
		cursor: pointer;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 5px;
	}

	.menu-bar {
		width: 18px;
		height: 2px;
		background: var(--fg);
		border-radius: 2px;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.menu-toggle[aria-expanded='true'] .menu-bar:nth-child(1) {
		transform: translateY(3.5px) rotate(45deg);
	}
	.menu-toggle[aria-expanded='true'] .menu-bar:nth-child(2) {
		transform: translateY(-3.5px) rotate(-45deg);
	}

	@media (max-width: 720px) {
		.menu-toggle { display: flex; }

		.primary-nav {
			position: absolute;
			top: 72px;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			gap: 2px;
			padding: 12px 24px 20px;
			background: var(--bg);
			border-bottom: 1px solid var(--line);
			transform: translateY(-12px);
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.18s ease, transform 0.18s ease;
		}

		.primary-nav[data-open='true'] {
			opacity: 1;
			transform: translateY(0);
			pointer-events: auto;
		}

		.nav-link {
			padding: 14px 0;
			font-size: 16px;
			margin: 0;
		}
		.nav-link::after {
			bottom: 4px;
		}
	}
</style>

<script is:inline>
	(function () {
		// ── Hamburger ──
		const btn = document.querySelector('.menu-toggle');
		const nav = document.getElementById('primary-nav');
		if (btn && nav) {
			btn.addEventListener('click', () => {
				const open = btn.getAttribute('aria-expanded') === 'true';
				btn.setAttribute('aria-expanded', String(!open));
				nav.dataset.open = String(!open);
			});
			nav.addEventListener('click', (e) => {
				if (e.target instanceof HTMLAnchorElement) {
					btn.setAttribute('aria-expanded', 'false');
					nav.dataset.open = 'false';
				}
			});
		}
	})();
</script>