---
import type { CollectionEntry } from 'astro:content';
import CoverArt from './CoverArt.astro';

export interface Props {
	project: CollectionEntry<'projects'>;
	priority?: boolean;
}

const { project, priority = false } = Astro.props;
const { title, description, tags, pubDate, cover, role } = project.data;

// Map cover key to generative SVG poster composition
const palette: Record<string, [string, string]> = {
	'motion-brand': ['#e85d3e', '#f5a623'],
	'tidal-doc': ['#26b6a8', '#1e62c9'],
	'sound-terrain': ['#9b5cf6', '#f25c54'],
	'neon-posters': ['#ff2e7e', '#6b2dff'],
	'ar-echo': ['#2fd889', '#22b6a8'],
};
const [c1, c2] = palette[cover ?? 'motion-brand'] ?? palette['motion-brand'];
const slug = project.id;
---

<article class="card" data-tags={tags.join('|')}>
	<a class="poster" href={`/projects/${slug}`} aria-label={`${title} 作品详情`}>
		<CoverArt cover={cover} c1={c1} c2={c2} slug={slug} />
		<span class="view">查看 →</span>
	</a>

	<div class="meta">
		<div class="row">
			<time class="date" datetime={pubDate.toISOString()}>
				{pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit' })}
			</time>
			{role && <span class="role">{role}</span>}
		</div>
		<h3 class="title"><a href={`/projects/${slug}`}>{title}</a></h3>
		<p class="desc">{description}</p>
		{
			tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)
		}
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background: var(--bg-elev);
		overflow: hidden;
		box-shadow: var(--shadow);
		transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
	}
	.card:hover {
		border-color: var(--line-strong);
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.poster {
		position: relative;
		display: block;
		aspect-ratio: 3 / 4;
		overflow: hidden;
		background: #000;
	}
	.card:hover .cover-art { transform: scale(1.05); }

	.view {
		position: absolute;
		left: 16px;
		bottom: 16px;
		padding: 6px 12px;
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg);
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid var(--line-strong);
		border-radius: 999px;
		backdrop-filter: blur(8px);
		opacity: 0;
		transform: translateY(6px);
		transition: opacity 0.2s ease, transform 0.2s ease;
	}
	.card:hover .view {
		opacity: 1;
		transform: translateY(0);
	}

	.meta {
		padding: 18px 18px 22px;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		margin-bottom: 10px;
	}

	.date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
	}
	.role {
		font-size: 11px;
		color: var(--fg-muted);
		font-family: var(--font-mono);
		padding: 3px 8px;
		border: 1px solid var(--line);
		border-radius: 999px;
	}

	.title {
		font-size: 19px;
		font-weight: 600;
		margin: 0 0 8px;
	}
	.title a:hover { color: var(--accent); }

	.desc {
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.6;
		margin: 0 0 14px;
		flex: 1;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.tags li {
		font-size: 11px;
		color: var(--fg-dim);
		font-family: var(--font-mono);
		padding: 3px 8px;
		border: 1px solid var(--line);
		border-radius: 999px;
	}
</style>