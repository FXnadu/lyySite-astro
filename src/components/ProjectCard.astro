---
import type { CollectionEntry } from 'astro:content';
import CoverArt from './CoverArt.astro';

export interface Props {
	project: CollectionEntry<'projects'>;
	priority?: boolean;
}

const { project, priority = false } = Astro.props;
const { title, description, tags, pubDate, cover } = project.data;

// Map cover key to generative SVG poster composition
const palette: Record<string, [string, string]> = {
	'motion-brand': ['#e85d3e', '#f5a623'],
	'tidal-doc': ['#26b6a8', '#1e62c9'],
	'sound-terrain': ['#9b5cf6', '#f25c54'],
	'neon-posters': ['#ff2e7e', '#6b2dff'],
	'ar-echo': ['#2fd889', '#22b6a8'],
};
const [c1, c2] = palette[cover ?? 'motion-brand'] ?? palette['motion-brand'];
const slug = project.id;
---

<article class="card" data-tags={tags.join('|')}>
	<a class="poster" href={`/projects/${slug}`} aria-label={`${title} 作品详情`}>
		<CoverArt cover={cover} c1={c1} c2={c2} slug={slug} />
		<span class="view">查看 →</span>
	</a>

	<div class="meta">
		<div class="row">
			<time class="date" datetime={pubDate.toISOString()}>
				{pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit' })}
			</time>
		</div>
		<h3 class="title"><a href={`/projects/${slug}`}>{title}</a></h3>
		<p class="desc">{description}</p>
		{
			tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)
		}
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--bg);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		overflow: hidden;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.card:hover {
		box-shadow: 0 4px 20px rgba(0,0,0,0.08);
	}

	.poster {
		position: relative;
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #000;
	}

	.view {
		position: absolute;
		right: 10px;
		bottom: 10px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: #fff;
		opacity: 0;
		transition: opacity 0.25s;
	}
	.poster:hover .view {
		opacity: 0.7;
	}

	.meta {
		padding: 12px;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.row {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 6px;
	}

	.date {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--fg-dim);
	}
	.title {
		font-family: var(--font-display);
		font-size: 16px;
		font-weight: 600;
		margin: 0 0 4px;
		line-height: 1.3;
	}
	.title a {
		color: var(--fg);
	}
	.title a:hover {
		color: var(--accent);
	}

	.desc {
		font-size: 13px;
		color: var(--fg-muted);
		line-height: 1.5;
		margin: 0 0 10px;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 4px;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.tags li {
		font-size: 10px;
		font-family: var(--font-mono);
		color: var(--accent);
		padding: 2px 7px;
		border: 1px solid var(--accent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}
</style>