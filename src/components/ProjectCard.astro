---
import type { CollectionEntry } from 'astro:content';
import CoverArt from './CoverArt.astro';

export interface Props {
	project: CollectionEntry<'projects'>;
	priority?: boolean;
}

const { project, priority = false } = Astro.props;
const { title, description, tags, pubDate, cover, role } = project.data;

// Map cover key to generative SVG poster composition
const palette: Record<string, [string, string]> = {
	'motion-brand': ['#e85d3e', '#f5a623'],
	'tidal-doc': ['#26b6a8', '#1e62c9'],
	'sound-terrain': ['#9b5cf6', '#f25c54'],
	'neon-posters': ['#ff2e7e', '#6b2dff'],
	'ar-echo': ['#2fd889', '#22b6a8'],
	'color-palette': ['#7c3aed', '#ec4899'],
};
const [c1, c2] = palette[cover ?? 'motion-brand'] ?? palette['motion-brand'];
const slug = project.id;
---

<article class="card" data-tags={tags.join('|')}>
	<a class="poster" href={`/projects/${slug}`} aria-label={`${title} 作品详情`}>
		<CoverArt cover={cover} c1={c1} c2={c2} slug={slug} />
		<span class="view">查看 →</span>
	</a>

	<div class="meta">
		<div class="row">
			<time class="date" datetime={pubDate.toISOString()}>
				{pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit' })}
			</time>
			{role && <span class="role">{role}</span>}
		</div>
		<h3 class="title"><a href={`/projects/${slug}`}>{title}</a></h3>
		<p class="desc">{description}</p>
		{
			tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)
		}
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.poster {
		position: relative;
		display: block;
		aspect-ratio: 3 / 4;
		overflow: hidden;
		background: #000;
		margin-bottom: 16px;
	}

	.view {
		position: absolute;
		right: 14px;
		bottom: 14px;
		font-family: var(--font-mono);
		font-size: 12px;
		color: #fff;
		opacity: 0;
		transition: opacity 0.25s;
	}
	.poster:hover .view {
		opacity: 0.7;
	}

	.meta {
		padding: 0;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.row {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 8px;
	}

	.date {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--fg-dim);
	}
	.role {
		font-size: 12px;
		color: var(--fg-muted);
	}

	.title {
		font-family: var(--font-display);
		font-size: 19px;
		font-weight: 600;
		margin: 0 0 6px;
		line-height: 1.3;
	}
	.title a {
		color: var(--fg);
	}
	.title a:hover {
		color: var(--accent);
	}

	.desc {
		font-size: 14px;
		color: var(--fg-muted);
		line-height: 1.6;
		margin: 0 0 14px;
		flex: 1;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.tags li {
		font-size: 12px;
		color: var(--fg-dim);
	}
	.tags li + li::before {
		content: '·';
		margin: 0 8px;
	}
</style>