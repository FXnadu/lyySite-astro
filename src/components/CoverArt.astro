---
export interface Props {
	cover?: string;
	c1: string;
	c2: string;
	slug: string;
}

const { cover = 'motion-brand', c1, c2, slug } = Astro.props;
const uid = slug.replace(/[^a-z0-9]/gi, '');
const seed = ({ motion: 3, tidal: 7, sound: 2, neon: 9, ar: 5 } as Record<string, number>)[cover.split('-')[0]] ?? 3;
---

<svg
	class="cover-art"
	viewBox="0 0 800 1000"
	preserveAspectRatio="xMidYMid slice"
	role="img"
	aria-hidden="true"
>
	<defs>
		<linearGradient id={`cg-${uid}`} x1="0" y1="0" x2="1" y2="1">
			<stop offset="0%" stop-color={c1} />
			<stop offset="100%" stop-color={c2} />
		</linearGradient>
		<filter id={`cn-${uid}`}>
			<feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="2" seed={seed} />
			<feColorMatrix type="saturate" values="0" />
		</filter>
		<filter id={`glow-${uid}`}>
			<feGaussianBlur stdDeviation="10" result="coloredBlur" />
			<feMerge>
				<feMergeNode in="coloredBlur" />
				<feMergeNode in="SourceGraphic" />
			</feMerge>
		</filter>
	</defs>

	<rect width="800" height="1000" fill={`url(#cg-${uid})`} />
	<g opacity="0.12" filter={`url(#cn-${uid})`}>
		<rect width="800" height="1000" />
	</g>

	{
		cover === 'motion-brand' && (
			<g fill="none" stroke-linecap="round">
				<rect
					x="-120"
					y="260"
					width="1200"
					height="160"
					rx="80"
					fill="rgba(255,255,255,0.20)"
					transform="rotate(32 400 500)"
				/>
				<rect
					x="-120"
					y="540"
					width="1200"
					height="90"
					rx="45"
					fill="rgba(0,0,0,0.16)"
					transform="rotate(32 400 500)"
				/>
				<circle cx="400" cy="500" r="230" stroke="rgba(255,255,255,0.32)" stroke-width="3" />
				<circle cx="400" cy="500" r="155" fill="rgba(0,0,0,0.10)" />
				<circle cx="620" cy="220" r="16" fill="rgba(255,255,255,0.45)" />
				<circle cx="180" cy="780" r="10" fill="rgba(0,0,0,0.25)" />
			</g>
		)
	}

	{
		cover === 'tidal-doc' && (
			<g fill="none" stroke-linecap="round">
				<rect x="130" y="210" width="540" height="360" rx="8" stroke="rgba(255,255,255,0.30)" stroke-width="2" />
				<g fill="rgba(255,255,255,0.35)">
					{[0, 1, 2, 3, 4, 5].map((i) => (
						<rect x="145" y={235 + i * 52} width="18" height="28" rx="3" />
					))}
					{[0, 1, 2, 3, 4, 5].map((i) => (
						<rect x="637" y={235 + i * 52} width="18" height="28" rx="3" />
					))}
				</g>
				<path d="M120 650 Q 260 560 400 650 T 680 650" stroke="rgba(255,255,255,0.35)" stroke-width="4" />
				<circle cx="400" cy="410" r="110" stroke="rgba(0,0,0,0.12)" stroke-width="2" />
				<line x1="0" y1="820" x2="800" y2="780" stroke="rgba(0,0,0,0.12)" stroke-width="2" />
			</g>
		)
	}

	{
		cover === 'sound-terrain' && (
			<g fill="none" stroke-linecap="round">
				<path
					d="M0 820 L70 760 L140 800 L210 700 L280 760 L350 660 L420 740 L490 650 L560 760 L630 690 L700 780 L800 740 V1000 H0 Z"
					fill="rgba(0,0,0,0.18)"
				/>
				<path
					d="M0 860 L60 820 L120 850 L180 780 L240 830 L300 760 L360 810 L420 740 L480 800 L540 750 L600 820 L660 770 L720 830 L800 790"
					stroke="rgba(255,255,255,0.35)"
					stroke-width="3"
				/>
				<circle cx="400" cy="360" r="160" stroke="rgba(255,255,255,0.20)" stroke-width="2" />
				<circle cx="400" cy="360" r="100" fill="rgba(0,0,0,0.10)" />
				<g fill="rgba(255,255,255,0.40)">
					{[0, 1, 2, 3, 4].map((i) => <circle cx={180 + i * 110} cy={230 + (i % 2) * 40} r="6" />)}
				</g>
			</g>
		)
	}

	{
		cover === 'neon-posters' && (
			<g fill="none" stroke-linecap="round">
				<rect x="210" y="230" width="380" height="540" rx="32" stroke="rgba(255,255,255,0.35)" stroke-width="4" filter={`url(#glow-${uid})`} />
				<rect x="170" y="300" width="460" height="400" rx="24" fill="rgba(0,0,0,0.18)" />
				<line x1="80" y1="140" x2="720" y2="860" stroke="rgba(255,255,255,0.22)" stroke-width="2" />
				<line x1="720" y1="140" x2="80" y2="860" stroke="rgba(255,255,255,0.22)" stroke-width="2" />
				<circle cx="400" cy="500" r="90" fill="rgba(255,255,255,0.12)" />
				<g fill="rgba(255,255,255,0.45)">
					<circle cx="160" cy="180" r="8" />
					<circle cx="640" cy="820" r="8" />
					<circle cx="640" cy="180" r="5" />
					<circle cx="160" cy="820" r="5" />
				</g>
			</g>
		)
	}

	{
		cover === 'ar-echo' && (
			<g fill="none" stroke-linecap="round">
				<circle cx="400" cy="500" r="280" stroke="rgba(255,255,255,0.26)" stroke-width="2" />
				<circle cx="400" cy="500" r="215" stroke="rgba(255,255,255,0.20)" stroke-width="2" />
				<circle cx="400" cy="500" r="150" stroke="rgba(255,255,255,0.14)" stroke-width="2" />
				<circle cx="400" cy="500" r="80" fill="rgba(0,0,0,0.12)" />
				<line x1="400" y1="120" x2="400" y2="880" stroke="rgba(255,255,255,0.25)" stroke-width="2" />
				<line x1="120" y1="500" x2="680" y2="500" stroke="rgba(255,255,255,0.25)" stroke-width="2" />
				<path d="M220 220 L280 220 L280 280 M580 220 L520 220 L520 280 M220 780 L280 780 L280 720 M580 780 L520 780 L520 720" stroke="rgba(255,255,255,0.35)" stroke-width="4" />
			</g>
		)
	}

	<g opacity="0.06" filter={`url(#cn-${uid})`}>
		<rect width="800" height="1000" fill="#000" />
	</g>
</svg>

<style>
	.cover-art {
		width: 100%;
		height: 100%;
		transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
	}
</style>
