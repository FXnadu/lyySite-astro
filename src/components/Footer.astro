---
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container bar">
		<div class="left">
			<span class="dot"></span>
			<p class="status">正在寻找数媒相关实习机会 · 广东</p>
		</div>
		<div class="right">
			<nav class="socials" aria-label="社交链接">
				<a class="social-btn" href="mailto:liuyingying@example.com" aria-label="邮件" title="邮件">
					<Icon name="lucide:mail" size={16} />
				</a>
				<a class="social-btn" href="weixin://contacts/profile/lyy_work" aria-label="微信" title="微信">
					<Icon name="simple-icons:wechat" size={16} />
				</a>
				<a class="social-btn" href="https://wpa.qq.com/msgrd?v=3&uin=123456789&site=qq&menu=yes" target="_blank" rel="noopener" aria-label="QQ" title="QQ">
					<Icon name="simple-icons:tencentqq" size={16} />
				</a>
			</nav>
			<p class="copy">© {year} liuyingying · 用 Astro 构建</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--line);
		padding-block: 36px 60px;
		background: var(--bg-soft);
	}

	.bar {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 32px;
		flex-wrap: wrap;
	}

	.left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 16%, transparent);
		animation: pulse 2.6s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.5; transform: scale(0.85); }
	}

	.status {
		margin: 0;
		font-size: 14px;
		color: var(--fg-muted);
		letter-spacing: -0.01em;
	}

	.right {
		text-align: right;
	}

	.socials {
		display: flex;
		gap: 10px;
		margin-bottom: 10px;
		justify-content: flex-end;
	}

	.social-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		border: 1.5px solid var(--accent);
		border-radius: 10px;
		box-shadow: 2px 2px 0 0 var(--accent);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.social-btn:hover {
		transform: translate(1px, 1px);
		box-shadow: 1px 1px 0 0 var(--accent);
	}

	.copy {
		margin: 0;
		font-size: 12px;
		color: var(--fg-dim);
	}

	@media (max-width: 600px) {
		.bar { flex-direction: column; align-items: flex-start; }
		.right { text-align: left; }
		.socials { justify-content: flex-start; }
	}
</style>