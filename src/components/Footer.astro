---
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container">
		<div class="footer-card">
			<div class="brand">
				<h2 class="name">liuyingying</h2>
				<p class="tagline">数字媒体 · 实习作品集</p>
			</div>

			<div class="contact">
				<p class="contact-title">联系我</p>
				<a class="email" href="mailto:liuyingying@example.com">liuyingying@example.com</a>
				<p class="location">广东 · 中国</p>
			</div>

			<div class="status">
				<span class="dot"></span>
				<p class="status-text">正在寻找数媒相关实习机会</p>
			</div>
		</div>

		<div class="bottom">
			<nav class="socials" aria-label="社交链接">
				<a class="social-btn" href="mailto:liuyingying@example.com" aria-label="邮件" title="邮件">
					<Icon name="lucide:mail" size={18} />
				</a>
				<a class="social-btn" href="weixin://contacts/profile/lyy_work" aria-label="微信" title="微信">
					<Icon name="simple-icons:wechat" size={18} />
				</a>
				<a class="social-btn" href="https://wpa.qq.com/msgrd?v=3&uin=123456789&site=qq&menu=yes" target="_blank" rel="noopener" aria-label="QQ" title="QQ">
					<Icon name="simple-icons:tencentqq" size={18} />
				</a>
			</nav>
			<p class="copy">© {year} liuyingying · 用 Astro 构建</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		border-top: 1px solid var(--line);
		padding-block: 56px 48px;
		background: var(--bg-soft);
	}
	.site-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		background:
			radial-gradient(circle at 10% 100%, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 35%),
			radial-gradient(circle at 90% 10%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 30%);
	}

	.container {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	.footer-card {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr 1fr;
		gap: 32px;
		padding: 28px;
		background: var(--bg);
		border: 1.5px solid var(--line);
		border-radius: var(--radius);
		box-shadow: 3px 3px 0 0 var(--line);
	}

	.name {
		margin: 0 0 6px;
		font-size: 22px;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--fg);
	}

	.tagline {
		margin: 0;
		font-size: 14px;
		color: var(--fg-muted);
	}

	.contact-title {
		margin: 0 0 10px;
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-dim);
	}

	.email {
		display: inline-block;
		margin-bottom: 8px;
		font-size: 14px;
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease;
	}
	.email:hover {
		border-color: var(--accent);
	}

	.location {
		margin: 0;
		font-size: 13px;
		color: var(--fg-muted);
	}

	.status {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 14px 18px;
		height: fit-content;
		align-self: start;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		border: 1.5px solid color-mix(in srgb, var(--accent) 25%, transparent);
	}

	.dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 16%, transparent);
		animation: pulse 2.6s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; transform: scale(1); }
		50% { opacity: 0.5; transform: scale(0.85); }
	}

	.status-text {
		margin: 0;
		font-size: 13px;
		font-weight: 500;
		color: var(--fg);
		white-space: nowrap;
	}

	.bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
		flex-wrap: wrap;
	}

	.socials {
		display: flex;
		gap: 12px;
	}

	.social-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, transparent);
		border: 1.5px solid var(--accent);
		border-radius: 12px;
		box-shadow: 3px 3px 0 0 var(--accent);
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.social-btn:hover {
		transform: translate(2px, 2px);
		box-shadow: 1px 1px 0 0 var(--accent);
	}

	.copy {
		margin: 0;
		font-size: 13px;
		color: var(--fg-dim);
	}

	@media (max-width: 720px) {
		.footer-card {
			grid-template-columns: 1fr;
			gap: 24px;
		}
		.status { align-self: stretch; justify-content: center; }
		.bottom { flex-direction: column; align-items: flex-start; }
	}
</style>
